{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expedia.dev/schemas/json/embedding-instance/0.1.0",
  "title": "EmbeddingInstance",
  "type": "object",
  "required": ["instance_id", "record_id", "profile_id", "vector_reference", "created_in", "runner_provenance", "eligibility_status"],
  "properties": {
    "instance_id": {"type": "string", "minLength": 1},
    "record_id": {"type": "string", "minLength": 1},
    "profile_id": {"type": "string", "minLength": 1},
    "vector_reference": {"type": "object", "required": ["shard_id", "row", "shard_digest"], "properties": {"shard_id": {"type": "string", "minLength": 1}, "row": {"type": "integer", "minimum": 0}, "shard_digest": {"type": "string", "minLength": 1}}},
    "created_in": {"type": "string", "minLength": 1},
    "runner_provenance": {"type": "object", "minProperties": 1},
    "eligibility_status": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
